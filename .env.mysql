# Local MySQL environment (used by run-local-mysql.ps1)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/movetedatabase_local
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

# Optional tuning
SERVER_PORT=8081
SPRING_DATASOURCE_MAXIMUM_POOL_SIZE=5
SPRING_DATASOURCE_MINIMUM_IDLE=2
SPRING_DATASOURCE_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_MAX_LIFETIME=1800000
